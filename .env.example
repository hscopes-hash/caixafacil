# Vercel Postgres - Variáveis de ambiente
# O Vercel injeta automaticamente essas variáveis ao conectar o banco

# URL com connection pooling (para uso no servidor)
POSTGRES_PRISMA_URL="postgres://default:xxxx@xxxx.postgres.vercel-storage.com/verceldb?pgbouncer=true&connect_timeout=15"

# URL direta (para migrations)
POSTGRES_URL_NON_POOLING="postgres://default:xxxx@xxxx.postgres.vercel-storage.com/verceldb?connect_timeout=15"

# ============================================
# Google Gemini - Extração de leitura por foto (GRATUITO)
# Configure essas variáveis no Vercel Dashboard → Settings → Environment Variables
# ============================================

# API Key do Google Gemini (gratuito)
# Como obter: https://aistudio.google.com/apikey
LLM_API_KEY="SUA_CHAVE_GEMINI_AQUI"

# Modelo Gemini (opcional - padrão: gemini-2.5-flash-lite)
# Opções: gemini-2.5-flash-lite (recomendado), gemini-2.0-flash, gemini-2.5-flash
# LLM_MODEL="gemini-2.5-flash-lite"
